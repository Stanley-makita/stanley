# Supabase — copiar do painel: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role — usado apenas na Edge Function aceitar-convite
# NUNCA expor no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Webhooks externos
# Use este valor na URL do webhook do Uazapi: /api/bot/whatsapp/webhook?token=...
UAZAPI_WEBHOOK_TOKEN=troque-por-um-token-longo-e-aleatorio

# SMTP — envio de e-mails (Hostinger ou outro provedor)
# host: smtp.hostinger.com | porta: 465 (SSL) ou 587 (STARTTLS)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seu-email@seudominio.com.br
SMTP_PASS=sua-senha-smtp-aqui
EMAIL_FROM=seu-email@seudominio.com.br
EMAIL_FROM_NAME=Credifon
